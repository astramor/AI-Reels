# ==========================================
# AI-Reels Konfiguration (.env)
# ==========================================

# --- API Keys & Provider ---
# GEMINI_API_KEY=dein_gemini_api_key_hier
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:14b-instruct-q6_K
GEMINI_MODEL=gemini-2.0-flash

# --- WhisperX / Transcription ---
WHISPER_MODEL=large-v2
# Optional (None = Auto-Detect):
# WHISPER_LANGUAGE=de

# --- CUDA / Device ---
WHISPER_DEVICE=cuda
WHISPER_DEVICE_INDEX=0

# --- Compute ---
# float16 für NVIDIA GPUs empfohlen (schneller, weniger VRAM)
WHISPER_COMPUTE_TYPE=float16

# --- Performance ---
WHISPER_BATCH_SIZE=16
WHISPER_THREADS=4
WHISPER_CHUNK_SIZE=30

# --- Alignment ---
# ALIGN_MODEL=WAV2VEC2_ASR_LARGE_LV60K_960H
ENABLE_ALIGNMENT=True
RETURN_CHAR_ALIGNMENTS=False

# --- VAD ---
VAD_METHOD=pyannote
VAD_ONSET=0.500
VAD_OFFSET=0.363

# --- Optional: Diarization ---
DIARIZATION_ENABLED=False
# MIN_SPEAKERS=1
# MAX_SPEAKERS=3

# --- FFmpeg & Video Encoding ---
FFMPEG_CRF=20
FFMPEG_PRESET=veryfast
NVENC=True
BLUR_BG=False
